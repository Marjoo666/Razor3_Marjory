<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, shrink-to-fit=no" />
    <title>@ViewData["Title"] - Portal Marjory Web</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/startbootstrap-sb-admin-2/4.1.4/css/sb-admin-2.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Razorr3_10266464.styles.css" asp-append-version="true" />
</head>
<body id="page-top">

    <div id="wrapper" style="display: flex;">

        <ul class="navbar-nav sidebar sidebar-dark accordion" style="background: linear-gradient(180deg, #4A148C 10%, #1A0033 100%) !important;">

            <a class="sidebar-brand d-flex align-items-center justify-content-center" asp-page="/Index">
                <div class="sidebar-brand-icon rotate-n-15">
                    <i class="fas fa-layer-group"></i>
                </div>
                <div class="sidebar-brand-text mx-3">Marjory Web</div>
            </a>

            <li><hr class="sidebar-divider my-0"></li>

            <li class="nav-item active">
                <a class="nav-link" asp-page="/Empleados/Index1">
                    <i class="fas fa-fw fa-columns"></i>
                    <span>Módulos del Sistema</span>
                </a>
            </li>

            <li><hr class="sidebar-divider"></li>

            <li class="nav-item">
                <a class="nav-link" asp-page="/Oficina">
                    <i class="fas fa-fw fa-building"></i>
                    <span>Oficinas</span>
                </a>
            </li>

            <li class="nav-item">
                <a class="nav-link" asp-page="/Empleados/Index">
                    <i class="fas fa-fw fa-user-tie"></i>
                    <span>Empleados</span>
                </a>
            </li>

            <li class="nav-item">
                <a class="nav-link" href="/Empleados/Cliente">
                    <i class="fas fa-fw fa-handshake"></i>
                    <span>Clientes</span>
                </a>
            </li>

            <li class="nav-item">
                <a class="nav-link" asp-page="/Empleados/AgregarEmpleados">
                    <i class="fas fa-fw fa-user-plus"></i>
                    <span>Agregar Empleados</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-page="/Empleados/ClientePractica">
                    <i class="fas fa-fw fa-plus-circle"></i>
                    <span>Agregar Cliente</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-page="/Empleados/OficinaPractica">
                    <i class="fas fa-fw fa-plus-square"></i>
                    <span>Agregar Oficina</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-page="/Empleados/EmpleadoContable">
                    <i class="fas fa-fw fa-wallet"></i>
                    <span>Finanzas y Contabilidad</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-page="/Empleados/EmpleadoDeveloper">
                    <i class="fas fa-fw fa-code"></i>
                    <span>Área de Ingeniería</span>
                </a>
            </li>

        </ul>

        <div id="content-wrapper" class="d-flex flex-column" style="flex-grow: 1; padding: 20px; background-color: #f8f9fc;">

            <main role="main" class="pb-3">
                @RenderBody()
            </main>

            <footer class="border-top footer text-muted mt-auto pt-3">
                <div class="container-fluid">
                    &copy; 2026 - Panel de Control Marjory - <a asp-area="" asp-page="/Privacy">Privacidad</a>
                </div>
            </footer>

        </div>



    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
    </div>
</body>
</html>
