@page
@model Razorr3_10266464.Pages.Empleados.ClienteModel
@{
    ViewData["Title"] = "Clientes";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a>Inicio</a></li>
        <li class="breadcrumb-item active"
            aria-current="page">Cliente</li>
    </ol>
</nav>
<div class="container-fluid mt-4">
    <div class="text-center">
        <div class="alert alert-primary" role="alert">
            <h1>Ejercicio: Seccion de Clientes</h1>
        </div>

    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Tabla de Clientes con FOREACH</h6>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-striped" width="100%" cellspacing="0">
                    <thead class="thead-dark">
                        <tr>
                            <th>#</th>
                            <th>Nombre Completo del Cliente</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int i = 1;
                        }
                        @foreach (var cliente in Model.ListaClientes)
                        {
                            <tr>
                                <td>@i</td>
                                <td>@cliente</td>
                            </tr>
                            i++;
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-success">Tabla de Clientes con WHILE</h6>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-hover" width="100%" cellspacing="0">
                    <thead class="bg-success text-white">
                        <tr>
                            <th>Indice</th>
                            <th>Nombre Completo del Cliente</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int index = 0;
                        }
                        @while (index < Model.ListaClientes.Count)
                        {
                            <tr>
                                <td>@index</td>
                                <td>@Model.ListaClientes[index]</td>
                            </tr>
                            index++;
                        }
                    </tbody>
                </table>
            </div>
            </div>
        </div>
    </div>
</div>
